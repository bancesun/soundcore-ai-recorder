# Copy this file to .env and fill in your own values.

# Timezone used for date detection and lookback windows.
TIMEZONE=Europe/Berlin
LOOKBACK_DAYS=14

# Obsidian vault/folder where one Markdown note per day will be written.
# Example:
# OBSIDIAN_VAULT=/Users/you/Library/Mobile Documents/iCloud~md~obsidian/Documents/全天AI录音
OBSIDIAN_VAULT=/path/to/your/obsidian/vault/全天AI录音

# Archive folder for original audio and full transcripts.
# For a mounted NAS on macOS this is often /Volumes/<share>/<folder>.
NAS_ARCHIVE=/Volumes/media/全天AI录音

# Optional: SMB URL to mount before running, used by scripts/run_daily.py.
# Store the password in macOS Keychain when Finder asks; do not put passwords here.
# Example: smb://username@nas-host.local/media
NAS_URL=
NAS_MOUNT_POINT=/Volumes/media
NAS_MOUNT_WAIT_SECONDS=120

# OpenAI transcription and summary.
# Get an API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
TRANSCRIBE_MODEL=whisper-1
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_LANGUAGE=Chinese
SUMMARY_DETAIL_LEVEL=detailed
SUMMARY_MIN_CHINESE_CHARS=5000
SUMMARY_MAX_TRANSCRIPT_CHARS=50000
SPEAKER_LABELS=true

# Cost control: remove ambient silence/noise before uploading to OpenAI Whisper.
# none | vad | silence
TRANSCRIBE_PREFILTER=vad
TRANSCRIBE_COMPRESS_AUDIO=true
TRANSCRIBE_AUDIO_BITRATE=32k
TRANSCRIBE_SEGMENT_SECONDS=300

# whisper.cpp Silero VAD. Install whisper-cpp with Homebrew and download the model.
VAD_COMMAND=/usr/local/bin/whisper-vad-speech-segments
VAD_MODEL=models/whisper.cpp/ggml-silero-v6.2.0.bin
VAD_THRESHOLD=0.45
VAD_MIN_SPEECH_MS=300
VAD_MIN_SILENCE_MS=700
VAD_SPEECH_PAD_MS=250
VAD_THREADS=4

# Browser automation.
# First run opens Chrome with a persistent profile. Log in to Soundcore once.
SOUNDCORE_BROWSER_CHANNEL=chrome
SOUNDCORE_HEADLESS=false

# Local transcription fallback. OpenAI Whisper is usually better for multilingual noisy audio.
USE_LOCAL_WHISPER=false
LOCAL_WHISPER_BACKEND=whisper_cpp
WHISPER_CPP_COMMAND=/usr/local/bin/whisper-cli
WHISPER_CPP_MODEL=models/whisper.cpp/ggml-medium-q5_0.bin
WHISPER_CPP_LANGUAGE=auto
WHISPER_CPP_THREADS=6
WHISPER_CPP_FAST=true

